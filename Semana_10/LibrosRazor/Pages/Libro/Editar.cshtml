@page
@model LibrosRazor.Pages.Libro.EditarModel

<link rel="stylesheet" href="~/css/crear.css" />

<h2>Editar Libro</h2>

<a href="/Index">Volver a la lista</a>

@if (!string.IsNullOrEmpty(Model.MensajeError))
{
    <p class="error">@Model.MensajeError</p>
}

<form method="post">
    @Html.AntiForgeryToken()

    <input type="hidden" asp-for="LibroForm.Id" />

    <div class="campo">
        <label>Titulo</label>
        <input type="text" asp-for="LibroForm.Titulo" />
    </div>

    <div class="campo">
        <label>Autor</label>
        <input type="text" asp-for="LibroForm.Autor" />
    </div>

    <div class="campo">
        <label>Precio</label>
        <input type="number" step="0.01" asp-for="LibroForm.Precio" />
    </div>

    <div class="campo">
        <label>Año</label>
        <input type="number" asp-for="LibroForm.Anio" />
    </div>

    <button type="submit">Guardar cambios</button>
</form>