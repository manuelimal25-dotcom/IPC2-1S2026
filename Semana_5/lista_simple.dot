digraph ListaSimple {
    // Configuración general
    bgcolor="#f5f5f5";
    label="Lista Simple de Pacientes";
    labelloc=t;
    fontsize=24;
    fontcolor="#1565c0";
    fontname="Helvetica Bold";
    node [fontname="Helvetica"];
    edge [fontname="Helvetica"];

    node0 [
        shape=record,
        style="filled,rounded",
        fillcolor="lightblue:white",
        gradientangle=90,
        color="#1976d2",
        penwidth=2,
        label="{
            <nombre> Nombre: Luis |
            <edad> Edad: 15 |
            <periodos> Períodos: 10 |
            <matriz> Matriz: 10x10 |
        }"
    ];

    node1 [
        shape=record,
        style="filled,rounded",
        fillcolor="lightblue:white",
        gradientangle=90,
        color="#1976d2",
        penwidth=2,
        label="{
            <nombre> Nombre: Pablo |
            <edad> Edad: 19 |
            <periodos> Períodos: 2 |
            <matriz> Matriz: 10x10 |
        }"
    ];

    node2 [
        shape=record,
        style="filled,rounded",
        fillcolor="lightblue:white",
        gradientangle=90,
        color="#1976d2",
        penwidth=2,
        label="{
            <nombre> Nombre: juan |
            <edad> Edad: 11 |
            <periodos> Períodos: 80 |
            <matriz> Matriz: 10x10 |
        }"
    ];

    node3 [
        shape=record,
        style="filled,rounded",
        fillcolor="lightblue:white",
        gradientangle=90,
        color="#1976d2",
        penwidth=2,
        label="{
            <nombre> Nombre: jose |
            <edad> Edad: 22 |
            <periodos> Períodos: 15 |
            <matriz> Matriz: 10x10 |
        }"
    ];

    node4 [
        shape=record,
        style="filled,rounded",
        fillcolor="lightblue:white",
        gradientangle=90,
        color="#1976d2",
        penwidth=2,
        label="{
            <nombre> Nombre: Jekaa |
            <edad> Edad: 19 |
            <periodos> Períodos: 25 |
            <matriz> Matriz: 20x20 |
        }"
    ];

    node5 [
        shape=record,
        style="filled,rounded",
        fillcolor="lightblue:white",
        gradientangle=90,
        color="#1976d2",
        penwidth=2,
        label="{
            <nombre> Nombre: Jessica |
            <edad> Edad: 19 |
            <periodos> Períodos: 12 |
            <matriz> Matriz: 20x20 |
        }"
    ];


    node0 -> node1 [
        color="#1976d2",
        penwidth=2.5,
        arrowsize=1.2
    ];
    node1 -> node2 [
        color="#1976d2",
        penwidth=2.5,
        arrowsize=1.2
    ];
    node2 -> node3 [
        color="#1976d2",
        penwidth=2.5,
        arrowsize=1.2
    ];
    node3 -> node4 [
        color="#1976d2",
        penwidth=2.5,
        arrowsize=1.2
    ];
    node4 -> node5 [
        color="#1976d2",
        penwidth=2.5,
        arrowsize=1.2
    ];
}
