@* @model ListaDrones *@

@{
    ViewData["Title"] = "Gestión de Drones";
}

<link rel="stylesheet" href="~/css/dron.css" />

<h1 class="titulo-seccion">Gestión de Drones</h1>

<form method="post" asp-action="Agregar" class="formulario-dron">
    <div class="formulario-grupo-dron">
        <label>Escribe el Nombre del Dron:</label>
        <input type="text" name="nombreDron" required />
    </div>
    <button type="submit" class="btn-accion btn-agregar-dron">
        Agregar Nuevo Dron
    </button>
</form>

<textarea class="cuadro-texto-dron" readonly>
@* Aquí irá la lista de drones *@
</textarea>

<div class="contenedor-botones">
    <form method="post" asp-action="MostrarLista">
        <button type="submit" class="btn-accion btn-ver-listado-dron">
            Ver Listado Drones
        </button>
    </form>
    
    <a href="@Url.Action("Index", "Home")">
        <button class="btn-accion btn-salir-dron">Salir</button>
    </a>
</div>