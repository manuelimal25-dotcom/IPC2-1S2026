@* @model ListaDrones *@

@{
    ViewData["Title"] = "Gestión de Drones";
}

<!-- Título de la sección -->
<h1 class="titulo-seccion">Gestión de Drones</h1>

<!-- Formulario para agregar dron -->
<form method="post" asp-action="Agregar">
    <div style="display: flex; gap: 10px; align-items: flex-end;">
        <div class="formulario-grupo">
            <label>Escribe el Nombre del Dron:</label>
            <input type="text" name="nombreDron" required />
        </div>
        <button type="submit" class="btn-accion" style="width: 230px;">
            Agregar Nuevo Dron
        </button>
    </div>
</form>

<!-- Área de texto para mostrar lista de drones -->
<textarea class="cuadro-texto" readonly>
@* Aquí irá la lista de drones cuando esté implementada *@
</textarea>

<!-- Botones de acción -->
<div class="contenedor-botones">
    <form method="post" asp-action="MostrarLista">
        <button type="submit" class="btn-accion" style="width: 230px;">
            Ver Listado Drones
        </button>
    </form>
    
    <a href="@Url.Action("Index", "Home")">
        <button class="btn-accion" style="width: 230px;">Salir</button>
    </a>
</div>