@{
    ViewData["Title"] = "Gestión Sistema de Drones";
}

<!-- Título de la sección -->
<h1 class="titulo-seccion">Sistemas de Drones Graficados</h1>

<!-- Mostrar imagen generada por Graphviz -->
<div style="text-align: center; margin-top: 50px;">
    @if (ViewBag.ImagenGenerada != null && ViewBag.ImagenGenerada == true)
    {
        <img src="~/images/sistemas_drones.png" 
             alt="Gráfica de Sistemas de Drones" 
             style="max-width: 100%; border: 2px solid #054279;" />
    }
    else
    {
        <p>No hay sistemas de drones para mostrar.</p>
    }
</div>

<!-- Botón salir -->
<div style="margin-top: 30px;">
    <a href="@Url.Action("Index", "Home")">
        <button class="btn-accion" style="width: 230px;">Salir</button>
    </a>
</div>