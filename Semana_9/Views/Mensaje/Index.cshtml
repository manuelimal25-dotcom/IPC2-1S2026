@model Semana_8.Models.ListaMensaje

@{
    ViewData["Title"] = "Gestión de Mensajes";
}

<link rel="stylesheet" href="~/css/mensaje.css" />

<h1 class="titulo-seccion">Gestión De Mensajes</h1>

<form method="post" asp-action="MostrarInformacion" class="formulario-mensaje">
    <div class="formulario-grupo-mensaje">
        <label>Escribe el Nombre del Mensaje:</label>
        <input type="text" name="nombreMensaje" required />
    </div>
    <button type="submit" class="btn-accion btn-mostrar-info-mensaje">
        Mostrar Información Mensaje
    </button>
</form>

<form method="post" asp-action="GraficarInstrucciones">
    <div class="formulario-grupo-mensaje">
        <input type="text" name="nombreMensaje" placeholder="Nombre del mensaje" required />
    </div>
    <button type="submit" class="btn-accion btn-graficar-mensaje">
        Gráficar Instrucciones Mensaje
    </button>
</form>

<textarea class="cuadro-texto-mensaje" readonly>
@if (ViewBag.ListadoMensajes != null)
{
@ViewBag.ListadoMensajes
}
else
{
@:Aquí irá la información del mensaje
}
</textarea>

<div class="contenedor-botones">
    <form method="post" asp-action="MostrarLista">
        <button type="submit" class="btn-accion btn-ver-listado-mensaje">
            Ver Listado Mensajes
        </button>
    </form>
    
    <a href="@Url.Action("Index", "Home")">
        <button class="btn-accion btn-salir-mensaje">Salir</button>
    </a>
</div>