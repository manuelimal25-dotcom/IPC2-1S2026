@model Semana_8.Models.ListaSistemas

@{
    ViewData["Title"] = "Gestión Sistema de Drones";
}

<link rel="stylesheet" href="~/css/sistema.css" />

<h1 class="titulo-seccion">Sistemas de Drones Graficados</h1>

<div class="contenedor-imagen-sistema">
    @if (Model != null && Model.GetCabeza() != null)
    {
        <div class="grid-imagenes-sistema">
            @{ var actual = Model.GetCabeza(); }
            @while (actual != null)
            {
                var nombreSistema = actual.GetDato().GetNombreSistema();
                var rutaImagen = "/images/sistemas/" + nombreSistema + ".png";
                <div class="tarjeta-sistema">
                    <img src="@rutaImagen?@DateTime.Now.Ticks" alt="Gráfica de Sistema de Drones" />
                    <p>@nombreSistema</p>
                </div>
                actual = actual.GetSiguiente();
            }
        </div>
    }
    else
    {
        <p>No hay sistemas de drones para mostrar.</p>
    }
</div>

<a href="@Url.Action("Index", "Home")">
    <button class="btn-accion btn-salir-sistema">Salir</button>
</a>